# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# env and secrets (never commit)
.env
.env.local
.env.*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# Capacitor / Android (machine-specific; keep android/ project in repo)
android/.gradle
android/app/build
android/build
android/local.properties
android/*.iml
android/captures
android/keystore.properties
android/*.jks
android/*.keystore

# typescript
*.tsbuildinfo
next-env.d.ts
